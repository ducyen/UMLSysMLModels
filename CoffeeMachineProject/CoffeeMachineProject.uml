  <Requirements:Requirement xmi:id="_5bKEwJm7Ee6x1MdWVRBwmA" base_NamedElement="_wexTUJggEe6x1MdWVRBwmA" id="SH-REQ-001" text="The coffee machine must provide a user-friendly interface with intuitive controls for selecting brewing options." base_Class="_wexTUJggEe6x1MdWVRBwmA"/>
  <MWPProfile.Requirements:StakeholderRequirement xmi:id="_JVMQ0JnCEe6x1MdWVRBwmA" verificationMethod="DEMONSTRATION" rationale="A user-friendly interface enhances the overall user experience, making it accessible to individuals with varying levels of familiarity with coffee machines. The customization feature caters to individual taste preferences, providing a personalized brewing experience." source="Marketing survey and user group questionnaires." base_Class="_wexTUJggEe6x1MdWVRBwmA" stakeholder="_1N-uQJXMEe6pELCKDZ6xnw"/>
  <Requirements:Requirement xmi:id="_mWMWUJnMEe6x1MdWVRBwmA" base_NamedElement="_mWKhIJnMEe6x1MdWVRBwmA" id="SH-REQ-002" text="The coffee machine design should prioritize cost-effectiveness in manufacturing without compromising on quality and performance." base_Class="_mWKhIJnMEe6x1MdWVRBwmA"/>
  <MWPProfile.Requirements:StakeholderRequirement xmi:id="_nDaosJnMEe6x1MdWVRBwmA" base_Class="_mWKhIJnMEe6x1MdWVRBwmA" stakeholder="_40P_cJXOEe6pELCKDZ6xnw"/>
  <Requirements:Requirement xmi:id="_o6CMEJnMEe6x1MdWVRBwmA" base_NamedElement="_o6BlAJnMEe6x1MdWVRBwmA" id="SH-REQ-003" text="The coffee machine design must incorporate a visually appealing and ergonomic layout, enhancing user experience." base_Class="_o6BlAJnMEe6x1MdWVRBwmA"/>
